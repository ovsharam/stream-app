# Production / FDE handoff defaults — copy to notch/.env or repo root .env
# Run: npm run dev:notch:live  (real integrations + live meeting path)

# Disable simulation — required for real Gmail, Monday, and post-call extraction
SIMULATION_MODE=false

# Do not set DEMO_MODE for production handoff (demo uses canned Acme fixtures)
# DEMO_MODE=

# Real meeting capture + KB assist (enabled by dev:notch:live)
NOTCH_PROTOTYPE=1

# LLM for post-call extraction and @claude / assist (required for full pipeline)
ANTHROPIC_API_KEY=

# Gmail OAuth (calendar rail + inbox feed) — same client as server GMAIL_* or GOOGLE_*
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Monday.com API token (connect in Apps → Monday)
# MONDAY_API_TOKEN=

# Optional: Google AI for @gemini and @monday NLP routing
# GEMINI_API_KEY=

# Data directory (default: ~/.stream-app)
# STREAM_DATA_DIR=

# FalkorDB graph — docker compose -f docker-compose.falkordb.yml up -d
# FALKORDB_URL=redis://localhost:6379
# FALKORDB_GRAPH=notch
# FALKORDB_ENABLED=1
