# Public URL (Vercel deployment)
APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_USE_POLLING=1

# Gmail OAuth (Docs/Drive use the same OAuth + scopes)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://your-app.vercel.app/api/auth/gmail/callback
# Optional GCP API key — same project as OAuth client; enable Drive + Docs APIs there
GOOGLE_API_KEY=

# Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=https://your-app.vercel.app/api/auth/slack/callback
SLACK_APP_TOKEN=xapp-...

# X / Twitter — API Key + Secret from developer.x.com → Keys and tokens
# For Notch OAuth: set as CLIENT_ID / CLIENT_SECRET (same values on most apps)
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3131/api/auth/x/callback

# Cal.com — API key from https://app.cal.com/settings/developer/api-keys
CALCOM_API_KEY=
# Default event slug on your Cal.com profile (e.g. 30min, discovery)
CALCOM_DEFAULT_EVENT_TYPE_SLUG=30min
# Optional — skip slug lookup if you know the numeric event type id
# CALCOM_EVENT_TYPE_ID=
# Optional if username isn't returned from profile
# CALCOM_USERNAME=your-cal-username
# CALCOM_TIMEZONE=America/New_York

# Cal.com OAuth (optional — requires Cal.com admin approval)
# CALCOM_CLIENT_ID=
# CALCOM_CLIENT_SECRET=
# CALCOM_REDIRECT_URI=http://localhost:3131/api/auth/calcom/callback
# CALCOM_SCOPES=BOOKING_READ BOOKING_WRITE EVENT_TYPE_READ PROFILE_READ SCHEDULE_READ
# CALCOM_USE_PKCE=0

# Server (local dev API on 3131; Vercel uses /api serverless)
PORT=3131
STREAM_DATA_DIR=
SESSION_SECRET=change-me-to-random-32-chars-min

# Demo mode (Acme sim + canned assist): npm run dev:notch:demo  (sets DEMO_MODE=1)
# Real P1 prototype (live meeting + KB assist): NOTCH_PROTOTYPE=1 npm run dev:notch
# NOTCH_PROTOTYPE=1

# Anthropic — used for @claude, meeting assist, and post-call extraction
ANTHROPIC_API_KEY=

# Google AI Studio — used for @gemini and @monday NLP routing
GEMINI_API_KEY=
